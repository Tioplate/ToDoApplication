<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.todo.todoapplication.mapper.UserMapper">

    <insert id="register" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (username, password, created_at, updated_at)
        VALUES (#{username}, #{password}, NOW(), NOW())
    </insert>

    <select id="findByUsername" resultType="com.todo.todoapplication.entity.User">
        SELECT id, username, password, created_at
        FROM users
        WHERE username = #{username}
    </select>

    <select id="findById" resultType="com.todo.todoapplication.entity.User">
        SELECT id, username, password, created_at
        FROM users
        WHERE id = #{id}
    </select>

    <update id="update">
        UPDATE users
        <set>
            <if test="username !=null and username != ''">username = #{username},</if>
            <if test="password !=null and password != ''">password = #{password},</if>
            <if test="(username !=null and username != '') || (password !=null and password != '')">
                updated_at = NOW()
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateByUsername">
        UPDATE users
        <set>
            <if test="user.username != null and user.username != ''">username = #{user.username},</if>
            <if test="user.password != null and user.password != ''">password = #{user.password},</if>
            <if test="(user.username != null and user.username != '') or (user.password != null and user.password != '')">
                updated_at = NOW()
            </if>
        </set>
        WHERE username = #{currentUsername}
    </update>

</mapper>